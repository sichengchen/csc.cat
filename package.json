{
  "name": "csc.cat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run --parallel dev",
    "build": "vp run -r build",
    "check": "vp check",
    "preview": "vp run @csc/web#preview",
    "cf:dev": "vp run build && wrangler dev",
    "deploy": "vp run build && wrangler deploy",
    "deploy:dry-run": "vp run build && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.97.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.28.2"
}
