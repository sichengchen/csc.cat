{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "csc-cat",
  "compatibility_date": "2026-06-03",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "routes": [
    {
      "pattern": "csc.cat",
      "custom_domain": true,
    },
    {
      "pattern": "www.csc.cat",
      "custom_domain": true,
    },
  ],
}
